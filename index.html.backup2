<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>威尔士语学习平台 - 现代化精美UI</title>
    
    <!-- 现代化CSS -->
    <link rel="stylesheet" href="css/modern-ui.css">
    
    <!-- Font Awesome图标 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- 现代化字体 -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* 现代化加载动画 */
        #modernLoading {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, #264653 0%, #457b9d 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.5s ease;
        }
        
        .modern-logo {
            font-size: 4rem;
            margin-bottom: 2rem;
            animation: modernPulse 2s infinite;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
        }
        
        .modern-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: modernSpin 1s linear infinite;
        }
        
        .modern-loading-text {
            color: white;
            margin-top: 1.5rem;
            font-size: 1.2rem;
            font-weight: 300;
            letter-spacing: 1px;
            opacity: 0.9;
        }
        
        @keyframes modernPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }
        
        @keyframes modernSpin {
            to { transform: rotate(360deg); }
        }
        
        /* 现代化浮动操作按钮 */
        .fab {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, #e63946 0%, #ff6b6b 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 4px 20px rgba(230, 57, 70, 0.4);
            cursor: pointer;
            z-index: 100;
            transition: all 0.3s ease;
            border: none;
        }
        
        .fab:hover {
            transform: scale(1.1);
            box-shadow: 0 8px 25px rgba(230, 57, 70, 0.5);
        }
        
        .fab:active {
            transform: scale(0.95);
        }
        
        /* 现代化波浪背景 */
        .wave-bg {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 100px;
            background: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMTAwJSIgaGVpZ2h0PSIxMDBweCIgdmlld0JveD0iMCAwIDEyODAgMTQwIiBwcmVzZXJ2ZUFzcGVjdFJhdGlvPSJub25lIiB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciPjxwYXRoIGZpbGw9IiNmZmZmZmYiIGZpbGwtb3BhY2l0eT0iMC4xIiBkPSJNMTI4MCAxNDBjLTI4MCAwLTI4MC0xNDAtNTYwLTE0MFMwIDAgMCAxNDBoMTI4MHYwWiIvPjwvc3ZnPg==');
            background-size: 100% 100px;
            opacity: 0.5;
        }
        
        /* 现代化玻璃态效果 */
        .glass-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        /* 现代化渐变文字 */
        .gradient-text {
            background: linear-gradient(90deg, #e63946, #ffd166, #2a9d8f);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>
</head>
<body>
    <!-- 现代化加载屏幕 -->
    <div id="modernLoading">
        <div class="modern-logo">🏴󠁧󠁢󠁷󠁬󠁳󠁿</div>
        <div class="modern-spinner"></div>
        <div class="modern-loading-text">正在加载现代化威尔士学习平台...</div>
    </div>
    
    <!-- 主容器 -->
    <div class="app-container" style="display: none;">
        <!-- 现代化头部 -->
        <header class="header">
            <div class="wave-bg"></div>
            <h1>
                <span>🏴󠁧󠁢󠁷󠁬󠁳󠁿</span>
                威尔士语学习平台
            </h1>
            <div class="subtitle">现代化精美UI • 移动端优先设计 • 流畅交互体验</div>
            <div class="tagline">4周掌握100高频表达 • 能进行3分钟基础对话</div>
            <div style="margin-top: 1rem; font-size: 0.9rem; color: rgba(255,255,255,0.8);">
                <i class="fas fa-calendar-alt"></i> 当前日期: <span id="currentDate"></span>
                <span style="margin: 0 10px;">•</span>
                <i class="fas fa-user-graduate"></i> 学习进度: <span id="progressCount">0</span>/100
            </div>
        </header>
        
        <!-- 现代化主内容 -->
        <div class="main-content">
            <!-- 现代化侧边栏 -->
            <aside class="sidebar">
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <i class="fas fa-compass"></i> 学习导航
                    </h3>
                    <ul class="nav-list">
                        <li class="nav-item">
                            <a href="#" class="nav-link active" data-module="dailyWords">
                                <i class="fas fa-book-open"></i>
                                <span>每日词汇</span>
                                <span class="badge">5</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link" data-module="commonPhrases">
                                <i class="fas fa-comments"></i>
                                <span>常用短语</span>
                                <span class="badge new">新</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link" data-module="pronunciation">
                                <i class="fas fa-volume-up"></i>
                                <span>发音练习</span>
                                <span class="badge basic">基础版</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link" data-module="wordList">
                                <i class="fas fa-list"></i>
                                <span>单词列表</span>
                                <span class="badge new">新</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link" data-module="search">
                                <i class="fas fa-search"></i>
                                <span>搜索翻译</span>
                                <span class="badge new">新</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="#" class="nav-link" data-module="culture">
                                <i class="fas fa-landmark"></i>
                                <span>威尔士文化</span>
                                <span class="badge new">新</span>
                            </a>
                        </li>
                    </ul>
                </div>
                
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <i class="fas fa-chart-line"></i> 学习进度
                    </h3>
                    <div style="margin-bottom: 1rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                            <span style="font-size: 0.9rem; color: #666;">今日进度</span>
                            <span style="font-weight: 600; color: #e63946;">25%</span>
                        </div>
                        <div class="progress-container">
                            <div class="progress-bar" style="width: 25%;"></div>
                        </div>
                    </div>
                    <div style="font-size: 0.9rem; color: #666;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                            <span>已学单词</span>
                            <span style="font-weight: 600;">42</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span>已学短语</span>
                            <span style="font-weight: 600;">18</span>
                        </div>
                    </div>
                </div>
                
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <i class="fas fa-cog"></i> 设置
                    </h3>
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                        <span style="font-size: 0.9rem;">暗色模式</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="darkModeToggle">
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <span style="font-size: 0.9rem;">发音自动播放</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="autoPlayToggle" checked>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </aside>
            
            <!-- 现代化内容区域 -->
            <main class="content-area">
                <!-- 每日词汇模块 -->
                <div id="dailyWordsModule" class="module-content">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                        <h2 style="font-size: 1.8rem; color: #264653;">
                            <i class="fas fa-book-open" style="margin-right: 10px;"></i>
                            今日词汇
                        </h2>
                        <div style="font-size: 0.9rem; color: #666;">
                            第 <span style="font-weight: 600; color: #e63946;">6</span> 天
                        </div>
                    </div>
                    
                    <!-- 单词卡片 -->
                    <div class="word-card hover-lift">
                        <div class="word-header">
                            <div class="word-text">
                                <div class="word-english">Please.</div>
                                <div class="word-welsh">Os gwelwch yn dda.</div>
                                <div class="word-pronunciation">os GWELL-ooch un THAH</div>
                            </div>
                            <div>
                                <span style="font-size: 0.9rem; color: #666; background: #f8f9fa; padding: 4px 12px; border-radius: 20px;">
                                    礼貌用语
                                </span>
                            </div>
                        </div>
                        
                        <div style="margin-bottom: 1.5rem;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                                <div style="flex: 1;">
                                    <div style="font-size: 0.9rem; color: #666; margin-bottom: 0.25rem;">中文翻译</div>
                                    <div style="font-size: 1.2rem; font-weight: 500; color: #264653;">请。</div>
                                </div>
                                <div style="flex: 1;">
                                    <div style="font-size: 0.9rem; color: #666; margin-bottom: 0.25rem;">词性</div>
                                    <div style="font-size: 1.2rem; font-weight: 500; color: #2a9d8f;">礼貌用语</div>
                                </div>
                            </div>
                            
                            <div style="background: #f8f9fa; padding: 1rem; border-radius: 12px; margin-top: 1rem;">
                                <div style="font-size: 0.9rem; color: #666; margin-bottom: 0.5rem;">使用示例</div>
                                <div style="font-size: 1rem; color: #264653; line-height: 1.6;">
                                    <div style="margin-bottom: 0.5rem;">
                                        <span style="color: #2a9d8f;">•</span> Os gwelwch yn dda, rhowch y llyfr i mi. (请把书给我。)
                                    </div>
                                    <div>
                                        <span style="color: #2a9d8f;">•</span> A gaf i ddŵr, os gwelwch yn dda? (请给我一杯水，好吗？)
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div style="display: flex; gap: 1rem;">
                            <button class="btn btn-primary press-effect" onclick="playPronunciation()">
                                <i class="fas fa-volume-up"></i>
                                发音
                            </button>
                            <button class="btn btn-outline press-effect" onclick="addToFlashcards()">
                                <i class="fas fa-plus"></i>
                                加入闪卡
                            </button>
                            <button class="btn btn-outline press-effect" onclick="markAsLearned()">
                                <i class="fas fa-check"></i>
                                标记已学
                            </button>
                        </div>
                    </div>
                    
                    <!-- 学习提示 -->
                    <div class="study-tip hover-lift">
                        <h4>💡 学习技巧</h4>
                        <p>威尔士语的"请"字面意思是"如果你愿意的话"。这是一个非常礼貌的表达，在正式场合和日常对话中都常用。尝试在今天的对话中至少使用三次这个短语来加深记忆。</p>
                    </div>
                    
                    <!-- 导航按钮 -->
                    <div style="display: flex; justify-content: space-between; margin-top: 2rem;">
                        <button class="btn btn-outline press-effect">
                            <i class="fas fa-arrow-left"></i>
                            上一个
                        </button>
                        <div style="display: flex; gap: 0.5rem;">
                            <div style="width: 10px; height: 10px; background: #e63946; border-radius: 50%;"></div>
                            <div style="width: 10px; height: 10px; background: #e9ecef; border-radius: 50%;"></div>
                            <div style="width: 10px; height: 10px; background: #e9ecef; border-radius: 50%;"></div>
                            <div style="width: 10px; height: 10px; background: #e9ecef; border-radius: 50%;"></div>
                            <div style="width: 10px; height: 10px; background: #e9ecef; border-radius: 50%;"></div>
                        </div>
                        <button class="btn btn-primary press-effect">
                            下一个
                            <i class="fas fa-arrow-right"></i>
                        </button>
                    </div>
                </div>
                
                <!-- 其他模块内容会通过JavaScript动态加载 -->
                <div id="otherModules" style="display: none;"></div>
            </main>
        </div>
        
        <!-- 现代化页脚 -->
        <footer class="footer">
            <div>威尔士语学习平台 © 2026</div>
            <div class="footer-links">
                <a href="#" class="footer-link">使用条款</a>
                <a href="#" class="footer-link">隐私政策</a>
                <a href="#" class="footer-link">联系我们</a>
                <a href="#" class="footer-link">帮助中心</a>
            </div>
        </footer>
    </div>
    
    <!-- 浮动操作按钮 -->
    <button class="fab" onclick="scrollToTop()" title="回到顶部">
        <i class="fas fa-arrow-up"></i>
    </button>
    
    <!-- 现代化JavaScript -->
    <script>
        // 页面加载完成
        window.addEventListener('load', function() {
            // 隐藏加载屏幕
            setTimeout(function() {
                const loadingScreen = document.getElementById('modernLoading');
                loadingScreen.style.opacity = '0';
                setTimeout(function() {
                    loadingScreen.style.display = 'none';
                    document.querySelector('.app-container').style.display = 'block';
                    
                    // 添加淡入动画
                    document.querySelector('.app-container').style.opacity = '0';
                    document.querySelector('.app-container').style.animation = 'fadeIn 0.5s ease forwards';
                }, 300);
            }, 1500);
            
            // 设置当前日期
            const now = new Date();
            const options = { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' };
            document.getElementById('currentDate').textContent = now.toLocaleDateString('zh-CN', options);
            
            // 初始化进度
            updateProgress();
            
            // 添加CSS动画
            const style = document.createElement('style');
            style.textContent = `
                @keyframes fadeIn {
                    from { opacity: 0; transform: translateY(20px); }
                    to { opacity: 1; transform: translateY(0); }
                }
                
                .fade-in {
                    animation: fadeIn 0.5s ease;
                }
            `;
            document.head.appendChild(style);
        });
        
        // 滚动到顶部
        function scrollToTop() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        }
        
        // 播放发音
        function playPronunciation() {
            const audio = new Audio('https://web-x0ya.onrender.com/tts?text=Os+gwelwch+yn+dda&lang=cy');
            audio.play().catch(e => console.log('音频播放失败:', e));
            
            // 添加播放反馈
            const btn = event.target.closest('button');
            if (btn) {
                btn.innerHTML = '<i class="fas fa-volume-up"></i> 播放中...';
                btn.disabled = true;
                
                setTimeout(() => {
                    btn.innerHTML = '<i class="fas fa-volume-up"></i> 发音';
                    btn.disabled = false;
                }, 2000);
            }
        }
        
        // 添加到闪卡
        function addToFlashcards() {
            const btn = event.target.closest('button');
            if (btn) {
                btn.innerHTML = '<i class="fas fa-check"></i> 已添加';
                btn.classList.remove('btn-outline');
                btn.classList.add('btn-success');
                btn.disabled = true;
                
                // 显示提示
                showToast('已添加到闪卡列表');
            }
        }
        
        // 标记为已学
        function markAsLearned() {
            const btn = event.target.closest('button');
            if (btn) {
                btn.innerHTML = '<i class="fas fa-check-double"></i> 已学习';
                btn.classList.remove('btn-outline');
                btn.classList.add('btn-success');
                btn.disabled = true;
                
                // 更新进度
                updateProgress();
                
                // 显示提示
                showToast('标记为已学习，进度已更新');
            }
        }
        
        // 更新进度
        function updateProgress() {
            const progressCount = document.getElementById('progressCount');
            const current = parseInt(progressCount.textContent) || 0;
            progressCount.textContent = current + 1;
            
            // 更新进度条
            const progressBar = document.querySelector('.progress-bar');
            const newWidth = Math.min(100, ((current + 1) / 100) * 100);
            progressBar.style.width = newWidth + '%';
        }
        
        // 显示提示
        function showToast(message) {
            // 创建toast元素
            const toast = document.createElement('div');
            toast.style.cssText = `
                position: fixed;
                bottom: 100px;
                right: 20px;
                background: #264653;
                color: white;
                padding: 12px 24px;
                border-radius: 12px;
                box-shadow: 0 4px 20px rgba(0,0,0,0.2);
                z-index: 1000;
                animation: slideIn 0.3s ease, fadeOut 0.3s ease 2.7s forwards;
                max-width: 300px;
                font-size: 0.9rem;
            `;
            toast.textContent = message;
            
            // 添加动画
            const style = document.createElement('style');
            style.textContent = `
                @keyframes slideIn {
                    from { transform: translateX(100%); opacity: 0; }
                    to { transform: translateX(0); opacity: 1; }
                }
                @keyframes fadeOut {
                    from { opacity: 1; }
                    to { opacity: 0; }
                }
            `;
            document.head.appendChild(style);
            
            document.body.appendChild(toast);
            
            // 3秒后移除
            setTimeout(() => {
                toast.remove();
                style.remove();
            }, 3000);
        }
        
        // 导航切换
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                
                // 移除所有active类
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                
                // 添加active类到当前链接
                this.classList.add('active');
                
                // 获取模块名称
                const module = this.getAttribute('data-module');
                
                // 显示加载状态
                const contentArea = document.querySelector('.content-area');
                contentArea.innerHTML = `
                    <div style="text-align: center; padding: 3rem;">
                        <div class="modern-spinner" style="margin: 0 auto 1.5rem;"></div>
                        <div style="color: #666; font-size: 1.1rem;">正在加载 ${this.querySelector('span').textContent}...</div>
                    </div>
                `;
                
                // 模拟加载延迟
                setTimeout(() => {
                    loadModule(module);
                }, 800);
            });
        });
        
        // 加载模块
        function loadModule(module) {
            let content = '';
            
            switch(module) {
                case 'dailyWords':
                    content = document.getElementById('dailyWordsModule').innerHTML;
                    break;
                case 'commonPhrases':
                    content = `
                        <div style="text-align: center; padding: 3rem;">
                            <h2 style="font-size: 1.8rem; color: #264653; margin-bottom: 1.5rem;">
                                <i class="fas fa-comments" style="margin-right: 10px;"></i>
                                常用短语
                            </h2>
                            <p style="color: #666; margin-bottom: 2rem;">正在开发中，即将推出...</p>
                            <button class="btn btn-primary" onclick="showToast('功能即将上线！')">
                                通知我
                            </button>
                        </div>
                    `;
                    break;
                // 其他模块类似...
                default:
                    content = `
                        <div style="text-align: center; padding: 3rem;">
                            <h2 style="font-size: 1.8rem; color: #264653; margin-bottom: 1.5rem;">
                                <i class="fas fa-cogs" style="margin-right: 10px;"></i>
                                功能开发中
                            </h2>
                            <p style="color: #666; margin-bottom: 2rem;">我们正在努力开发这个功能，敬请期待！</p>
                            <button class="btn btn-primary" onclick="showToast('感谢您的耐心等待！')">
                                我知道了
                            </button>
                        </div>
                    `;
            }
            
            document.querySelector('.content-area').innerHTML = content;
            
            // 添加淡入效果
            document.querySelector('.content-area').style.animation = 'fadeIn 0.5s ease';
        }
        
        // 暗色模式切换
        document.getElementById('darkModeToggle').addEventListener('change', function() {
            document.body.classList.toggle('dark-mode', this.checked);
            showToast(this.checked ? '已切换到暗色模式' : '已切换到亮色模式');
        });
        
        // 自动播放切换
        document.getElementById('autoPlayToggle').addEventListener('change', function() {
            showToast(this.checked ? '发音自动播放已开启' : '发音自动播放已关闭');
        });
        
        // 监听滚动显示/隐藏FAB
        let lastScrollTop = 0;
        const fab = document.querySelector('.fab');
        
        window.addEventListener('scroll', function() {
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            
            if (scrollTop > lastScrollTop && scrollTop > 100) {
                // 向下滚动
                fab.style.transform = 'translateY(100px)';
                fab.style.opacity = '0';
            } else {
                // 向上滚动或顶部
                fab.style.transform = 'translateY(0)';
                fab.style.opacity = '1';
            }
            
            lastScrollTop = scrollTop;
        });
    </script>
</body>
</html>
